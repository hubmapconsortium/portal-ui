    "build:analyze": "ANALYZE=1 vite build",
    "build:maintain": "vite build --config vite.config.maintenance.mts",
    "dev-server": "vite",
    "dev-server:maintain": "vite --config vite.config.maintenance.mts",
    "test": "vitest run",
    "test:watch": "vitest",
